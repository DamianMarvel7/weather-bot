# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# Visual Crossing API key (for fetching actual historical temperatures)
# Used by auto-resolution and calibration accuracy.
# Get one free at: https://www.visualcrossing.com/weather-api
VC_KEY=your_visual_crossing_key_here

# Telegram bot notifications (optional)
# Create a bot via @BotFather on Telegram to get a token.
# Get your chat_id by messaging @userinfobot.
TELEGRAM_TOKEN=123456789:ABCdefGHI...
TELEGRAM_CHAT_ID=123456789
